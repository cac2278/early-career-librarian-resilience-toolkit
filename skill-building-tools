      }

      .translator-actions button:hover,
      .translator-actions button:focus {
        text-decoration: underline;
      }

      .translator-output {
        margin-top: 1.5rem;
      }

      .translation-callout {
        border: 1px solid #222;
        padding: 1rem;
        margin-bottom: 1rem;
        background: #f8f5ef;
      }

      .translation-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      .translation-card {
        border: 1px solid #222;
        padding: 1rem;
        background: #f8f5ef;
      }

      .translation-card h3 {
        margin-top: 0;
      }

      .translation-card ul {
        padding-left: 1.25rem;
      }

      .translation-card li {
