    <script>
      (function () {
        const form = document.getElementById('career-translator-form');
        const output = document.getElementById('career-translator-output');
        const resetButton = document.getElementById('career-translator-reset');

        function checkedValues(name) {
          return Array.from(document.querySelectorAll('input[name="' + name + '"]:checked')).map(function (input) {
            return input.value;
          });
        }

        function radioValue(name) {
          const selected = document.querySelector('input[name="' + name + '"]:checked');
          return selected ? selected.value : '';
        }

        function unique(items) {
          return Array.from(new Set(items));
        }

        function list(items) {
          return items.map(function (item) {
            return '<li>' + item + '</li>';
          }).join('');
        }

        function buildStrengths(fields, skills) {
          let strengths = [];

          if (skills.includes('service')) strengths.push('Public service and user-centered support');
          if (skills.includes('teaching')) strengths.push('Instruction, training, and learning support');
          if (skills.includes('supervision')) strengths.push('Personnel coordination and leadership');
          if (skills.includes('projects')) strengths.push('Project management and workflow planning');
          if (skills.includes('research')) strengths.push('Research support and information-seeking skills');
          if (skills.includes('writing')) strengths.push('Clear communication and documentation');
          if (skills.includes('events')) strengths.push('Programming and outreach');
          if (skills.includes('technology')) strengths.push('Technology support and digital troubleshooting');
          if (skills.includes('outreach')) strengths.push('Community engagement and partnership-building');
          if (skills.includes('records')) strengths.push('Information organization and records management');

          if (fields.includes('education')) strengths.push('Experience helping people learn');
          if (fields.includes('healthcare')) strengths.push('Care-centered service and confidentiality awareness');
          if (fields.includes('technology')) strengths.push('Comfort with systems, tools, and technical problem-solving');
          if (fields.includes('nonprofit')) strengths.push('Mission-driven community work');
          if (fields.includes('arts')) strengths.push('Cultural heritage, interpretation, and creative programming');

          return unique(strengths);
        }

        function buildTranslations(skills) {
          let translations = [];

          if (skills.includes('service')) translations.push('<strong>Customer service</strong> becomes <strong>public services, patron support, and reference desk readiness</strong>.');
          if (skills.includes('teaching')) translations.push('<strong>Teaching or training</strong> becomes <strong>library instruction, information literacy, and workshop facilitation</strong>.');
          if (skills.includes('supervision')) translations.push('<strong>Supervising staff</strong> becomes <strong>personnel management, student worker supervision, and team coordination</strong>.');
          if (skills.includes('projects')) translations.push('<strong>Project management</strong> becomes <strong>program coordination, implementation planning, and assessment follow-through</strong>.');
          if (skills.includes('research')) translations.push('<strong>Research experience</strong> becomes <strong>reference, research consultation, and information discovery support</strong>.');
          if (skills.includes('writing')) translations.push('<strong>Writing and communications</strong> becomes <strong>guides, documentation, outreach, web content, and instructional materials</strong>.');
          if (skills.includes('events')) translations.push('<strong>Event planning</strong> becomes <strong>library programming, outreach events, exhibits, and community engagement</strong>.');
          if (skills.includes('technology')) translations.push('<strong>Technology support</strong> becomes <strong>digital literacy, troubleshooting, makerspace support, and emerging technology services</strong>.');
          if (skills.includes('outreach')) translations.push('<strong>Community outreach</strong> becomes <strong>liaison work, partnerships, engagement, and inclusive services</strong>.');
          if (skills.includes('records')) translations.push('<strong>Records or file management</strong> becomes <strong>metadata thinking, information organization, archives, and collection stewardship</strong>.');

          return translations;
        }

        function buildResumeBullets(skills, setting) {
          let bullets = [];

          if (skills.includes('service')) bullets.push('Provided responsive, user-centered support to diverse communities in high-volume service environments.');
          if (skills.includes('teaching')) bullets.push('Designed and delivered instruction, training, or learning support tailored to varied experience levels.');
          if (skills.includes('research')) bullets.push('Assisted users with locating, evaluating, and applying information to meet practical or academic needs.');
          if (skills.includes('projects')) bullets.push('Coordinated projects from planning through completion, balancing timelines, communication, and stakeholder needs.');
          if (skills.includes('technology')) bullets.push('Supported users with technology tools, troubleshooting, and digital workflows.');
          if (skills.includes('events')) bullets.push('Planned and facilitated programs, events, or workshops that supported community learning and engagement.');
          if (skills.includes('records')) bullets.push('Organized records, files, or data using consistent systems to improve access, retrieval, and continuity.');
          if (skills.includes('outreach')) bullets.push('Built relationships with community partners and connected users with relevant resources and services.');

          if (setting === 'academic') bullets.push('Connected users with research support, learning resources, and academic success services.');
          if (setting === 'public') bullets.push('Supported welcoming, inclusive public services for users with a wide range of needs and goals.');
          if (setting === 'archives') bullets.push('Helped preserve, describe, or contextualize materials for long-term access and use.');

          return unique(bullets);
        }

        function buildGrowthAreas(growth, setting, mlis) {
          let areas = [];

          if (growth.includes('reference')) areas.push('Practice reference interviews and research consultations.');
          if (growth.includes('instruction')) areas.push('Explore information literacy instruction and lesson design.');
          if (growth.includes('cataloging')) areas.push('Learn basic cataloging, metadata, controlled vocabularies, and description standards.');
          if (growth.includes('collections')) areas.push('Explore collection development, weeding, licensing, and community-responsive collections.');
          if (growth.includes('archives')) areas.push('Learn archival arrangement, description, preservation, and donor/community relations.');
          if (growth.includes('assessment')) areas.push('Build comfort with surveys, usage data, outcomes, and service assessment.');
          if (growth.includes('management')) areas.push('Develop supervision, budgeting, planning, and change-management language.');

          if (setting === 'academic') areas.push('Learn about information literacy, liaison work, scholarly communication, and student success.');
          if (setting === 'public') areas.push('Explore programming, readers advisory, community partnerships, and inclusive public service.');
          if (setting === 'school') areas.push('Explore youth services, curriculum support, school library standards, and student learning.');
          if (setting === 'archives') areas.push('Explore archival ethics, description, preservation, access, and community archives.');
          if (setting === 'health') areas.push('Explore evidence-based practice, health information literacy, and database searching.');
          if (setting === 'law-government') areas.push('Explore legal or government information, policy research, records, and specialized reference.');

          if (mlis === 'considering' || mlis === 'no') areas.push('Look at job descriptions for roles that interest you and compare required qualifications with preferred qualifications.');

          return unique(areas);
        }

        function buildInterviewTalkingPoints(skills, setting) {
          let points = [];

          if (skills.includes('service')) points.push('My background in public-facing work prepared me to listen carefully, clarify needs, and help people feel welcome.');
          if (skills.includes('teaching')) points.push('My teaching or training experience helps me explain complex information in approachable ways.');
          if (skills.includes('research')) points.push('My research experience helps me support users as they define questions, search strategically, and evaluate sources.');
          if (skills.includes('technology')) points.push('My technology experience helps me troubleshoot problems and support digital literacy without making users feel judged.');
          if (skills.includes('outreach')) points.push('My outreach experience helps me build trust, create partnerships, and connect services to community needs.');
          if (skills.includes('records')) points.push('My experience organizing information translates directly to libraries because access depends on clear systems.');
          if (skills.includes('projects')) points.push('My project coordination experience helps me manage timelines, communication, and follow-through.');
          if (skills.includes('writing')) points.push('My writing and communication experience helps me make information clearer and more usable.');

          if (setting === 'academic') points.push('I am interested in academic libraries because they combine teaching, research support, and student-centered service.');
          if (setting === 'public') points.push('I am interested in public libraries because they connect people with information, technology, programs, and community support.');
          if (setting === 'archives') points.push('I am interested in archives because preserving context and access helps communities shape how their histories are remembered.');
          if (setting === 'school') points.push('I am interested in school libraries because they support student learning, curiosity, and equitable access to information.');
          if (setting === 'health') points.push('I am interested in health sciences libraries because they connect people with evidence-based information that supports care, learning, and decision-making.');
          if (setting === 'law-government') points.push('I am interested in law or government libraries because they support access to specialized information, public records, policy, and research.');

          return unique(points);
        }

        function buildProfessionalDevelopment(setting, growth, mlis) {
          let pd = [];

          pd.push('Review librarian job postings and highlight repeated skills, tools, and responsibilities.');
          pd.push('Conduct informational interviews with librarians in settings that interest you.');
          pd.push('Translate your existing experience into library language on your resume and cover letters.');

          if (mlis === 'student') pd.push('Use class projects to build portfolio examples connected to the library setting you want.');
          if (mlis === 'considering' || mlis === 'no') pd.push('Compare paraprofessional, library assistant, and MLIS-required roles to understand possible entry points.');

          if (setting === 'academic') pd.push('Explore instruction, reference, student success, and liaison librarianship.');
          if (setting === 'public') pd.push('Explore programming, outreach, technology help, and community partnerships.');
          if (setting === 'archives') pd.push('Explore community archives, metadata, preservation, and archival description.');
          if (setting === 'school') pd.push('Explore youth services, curriculum support, school library standards, and student learning.');
          if (growth.includes('cataloging')) pd.push('Try a short metadata or cataloging workshop.');
          if (growth.includes('instruction')) pd.push('Build one sample lesson plan, workshop outline, or research guide.');
          if (growth.includes('assessment')) pd.push('Practice turning service stories into measurable outcomes.');

          return unique(pd);
        }

        form.addEventListener('submit', function (event) {
          event.preventDefault();

          const fields = checkedValues('field');
          const skills = checkedValues('skills');
          const setting = radioValue('setting');
          const growth = checkedValues('growth');
          const mlis = radioValue('mlis');

          if (fields.length === 0 || skills.length === 0) {
            output.hidden = false;
            output.innerHTML = '<div class="translation-callout"><strong>Almost there:</strong> Select at least one field and one kind of work experience to generate your translation.</div>';
            return;
          }

          const strengths = buildStrengths(fields, skills);
          const translations = buildTranslations(skills);
          const bullets = buildResumeBullets(skills, setting);
          const growthAreas = buildGrowthAreas(growth, setting, mlis);
          const talkingPoints = buildInterviewTalkingPoints(skills, setting);
          const pd = buildProfessionalDevelopment(setting, growth, mlis);

          output.hidden = false;

          output.innerHTML = `
            <div class="translation-callout">
              <strong>Your experience counts.</strong> The goal is not to erase your previous career. The goal is to translate it into library language.
            </div>

            <div class="translation-grid">
              <div class="translation-card">
                <h3>Your Existing Strengths</h3>
                <ul>${list(strengths)}</ul>
              </div>

              <div class="translation-card">
                <h3>How Libraries Describe Those Skills</h3>
                <ul>${list(translations)}</ul>
              </div>

              <div class="translation-card">
                <h3>Resume Language You Can Adapt</h3>
                <ul>${list(bullets)}</ul>
              </div>

              <div class="translation-card">
                <h3>Recommended Areas to Explore</h3>
                <ul>${list(growthAreas)}</ul>
              </div>

              <div class="translation-card">
                <h3>Professional Development Ideas</h3>
                <ul>${list(pd)}</ul>
              </div>

              <div class="translation-card">
                <h3>Interview Talking Points</h3>
                <ul>${list(talkingPoints)}</ul>
              </div>
            </div>
          `;
        });

        resetButton.addEventListener('click', function () {
          form.reset();
          output.hidden = true;
          output.innerHTML = '';
        });
      })();
    </script>
  </body>
