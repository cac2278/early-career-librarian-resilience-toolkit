      .translator-form {
        margin-top: 1.5rem;
      }

      .translator-form fieldset {
        border: 1px solid var(--border-color, #222);
        padding: 1rem;
        margin: 1rem 0;
        background: var(--soft-background, #f8f5ef);
      }

      .translator-form legend {
        font-weight: 700;
        padding: 0 0.35rem;
      }

      .translator-form label {
        display: block;
        margin: 0.55rem 0;
